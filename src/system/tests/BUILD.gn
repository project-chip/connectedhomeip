import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")

import("${chip_root}/build/chip/chip_test_suite.gni")
import("${chip_root}/src/inet/inet.gni")
import("../system.gni")

chip_test_suite("tests") {
  output_name = "libSystemLayerTests"

  test_sources = [
    "TestEventLoopHandler.cpp",
    "TestSystemClock.cpp",
    "TestSystemErrorStr.cpp",
    "TestSystemScheduleLambda.cpp",
    "TestSystemScheduleWork.cpp",
    "TestSystemTimer.cpp",
    "TestTimeSource.cpp",
  ]

  # ESP32 TCP uses PBUF_RAM packet buffers, which always allocate at the TCP
  # maximum capacity. These tests assume requested sizes control buffer
  # capacity, so leave them out of the TCP-enabled QEMU configuration.
  if (!(chip_device_platform == "esp32" && chip_inet_config_enable_tcp_endpoint)) {
    test_sources += [ "TestSystemPacketBuffer.cpp" ]
  }

  # SystemPacketBuffer on nrfconnect/esp32 uses LwIP buffers, which ignore the
  #  requested allocation size and always allocate at max-size.  So our test,
  #  which tries to size-limit the buffers, does not work correctly there.
  if (chip_device_platform != "nrfconnect" && chip_device_platform != "esp32") {
    test_sources += [ "TestTLVPacketBufferBackingStore.cpp" ]
  }

  if (chip_system_config_event_loop == "Select") {
    test_sources += [
      "TestSystemEventSource.cpp",
      "TestSystemWakeEvent.cpp",
    ]
  }

  cflags = [ "-Wconversion" ]

  public_deps = [
    "${chip_root}/src/inet",
    "${chip_root}/src/lib/core:string-builder-adapters",
    "${chip_root}/src/lib/support/tests:pw-test-macros",
    "${chip_root}/src/platform",
    "${chip_root}/src/system",
  ]
}
