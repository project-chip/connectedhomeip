import("//build_overrides/chip.gni")
import("//build_overrides/efr32_sdk.gni")
import("${chip_root}/src/platform/silabs/wifi/args.gni")  # for wifi_sdk_root
import("${silabs_sdk_build_root}/efr32_sdk.gni")

assert(silabs_board_lower != "", "silabs_board_lower must be specified")

# Include paths required by the SiWx917 NCP sources (BLE bits from WiFi SDK)
config("siwx-ncp-config") {
  # Suppress VLA warnings for wifi-sdk files that use variable-length arrays
  # (same as SiWx917_sdk.gni for SoC builds)
  cflags = [ "-Wno-vla" ]

  include_dirs = [
    "${efr32_sdk_root}/platform_core/platform/service/mem_pool/inc/",
    "${wifi_sdk_root}/components/common/inc",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/ble/inc",
    "${chip_root}/third_party/silabs/simplicity_sdk/platform_core/platform/common/inc",
    "${chip_root}/third_party/silabs/simplicity_sdk/cmsis/RTOS2/Include",
    "${chip_root}/third_party/silabs/simplicity_sdk/freertos/kernel/include",
    "${wifi_sdk_root}/components/protocol/wifi/inc",
    "${chip_root}/third_party/silabs/simplicity_sdk/platform_core/platform/emdrv/dmadrv/src",
    "${chip_root}/third_party/silabs/simplicity_sdk/platform_core/platform/emdrv/dmadrv/inc",
    "${chip_root}/third_party/silabs/simplicity_sdk/platform_core/platform/emdrv/spidrv/inc",
    "${chip_root}/examples/platform/silabs",
    "${chip_root}/src/platform/silabs/SiWx/ble",
    "${wifi_sdk_root}/components/board/silabs/config/${silabs_board_lower}",
    "${wifi_sdk_root}/components/device/silabs/si91x/mcu/drivers/service/sl_log/inc",
    "${wifi_sdk_root}/components/sli_wifi/inc",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/inc",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sli_hal_si91x/inc",
    "${wifi_sdk_root}/components/sli_buffer_manager/inc",
    "${wifi_sdk_root}/components/device/silabs/si91x/mcu/drivers/service/memory_manager/inc",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sli_si91x_wifi_command_engine/inc",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sli_si91x_wifi_event_handler/inc",
    "${wifi_sdk_root}/components/sli_command_engine/inc",
    "${wifi_sdk_root}/components/sli_event_engine/inc",
    "${wifi_sdk_root}/components/sli_queue_manager/inc",
    "${wifi_sdk_root}/components/sli_routing_utility/inc",
  ]
}

source_set("siwx-ncp") {
  sources = [
    # TODO: Prefer using Wiseconnect SDK provided host file instead of this copy
    "${chip_root}/src/platform/silabs/wifi/SiWx/ncp/sl_si91x_ncp_utility.c",
    "${chip_root}/src/platform/silabs/wifi/ncp/spi_multiplex.h",

    # si91x_support component
    # sl_si91x_wireless component
    "${wifi_sdk_root}/components/common/src/sl_utility.c",

    # si91x_basic_buffers component
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/memory/malloc_buffers.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/ncp_interface/sl_si91x_ncp_driver.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/ncp_interface/spi/sl_si91x_spi.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sl_net/src/sl_net_rsi_utility.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sl_net/src/sl_net_si91x_callback_framework.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sl_net/src/sl_net_si91x_integration_handler.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sl_net/src/sli_net_si91x_utility.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sli_hal_si91x/src/sli_hal_si91x.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/src/sl_rsi_utility.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/src/sl_si91x_driver.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/src/sli_si91x_driver.c",
    "${wifi_sdk_root}/components/sli_wifi/src/sli_wifi_power_profile.c",

    # wifi component
    "${wifi_sdk_root}/components/protocol/wifi/src/sl_wifi_basic_credentials.c",
    "${wifi_sdk_root}/components/protocol/wifi/src/sl_wifi_callback_framework.c",
    "${wifi_sdk_root}/components/service/network_manager/src/sl_net.c",

    # network_manager component
    "${wifi_sdk_root}/components/service/network_manager/src/sl_net_basic_certificate_store.c",
    "${wifi_sdk_root}/components/service/network_manager/src/sl_net_basic_profiles.c",
    "${wifi_sdk_root}/components/sli_queue_manager/src/sli_queue_manager.c",

    # basic_network_manager component
    "${efr32_sdk_root}/platform_core/platform/service/mem_pool/src/sl_mem_pool.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/host_mcu/efx32/efx32_ncp_host.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sli_si91x_wifi_command_engine/src/sli_si91x_wifi_command_engine.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sli_si91x_wifi_command_engine/src/sli_si91x_wifi_command_engine_config.c",
    "${wifi_sdk_root}/components/device/silabs/si91x/wireless/sli_si91x_wifi_event_handler/src/sli_si91x_wifi_event_handler.c",
    "${wifi_sdk_root}/components/service/network_manager/src/si91x/sl_net_credentials.c",
    "${wifi_sdk_root}/components/service/network_manager/src/sl_net_for_lwip.c",
    "${wifi_sdk_root}/components/service/network_manager/src/sli_net_common_utility.c",
    "${wifi_sdk_root}/components/service/network_manager/src/sli_net_credentials.c",
    "${wifi_sdk_root}/components/sli_buffer_manager/src/sli_buffer_manager.c",
    "${wifi_sdk_root}/components/sli_command_engine/src/sli_command_engine.c",
    "${wifi_sdk_root}/components/sli_event_engine/src/sli_event_engine.c",
    "${wifi_sdk_root}/components/sli_routing_utility/src/sli_routing_utility.c",

    # utility
    "${wifi_sdk_root}/components/device/silabs/si91x/mcu/drivers/service/memory_manager/src/sl_si91x_memory_manager.c",
    "${wifi_sdk_root}/components/protocol/wifi/src/si91x/sl_wifi.c",
    "${wifi_sdk_root}/components/protocol/wifi/src/sli_wifi_callback_framework.c",
    "${wifi_sdk_root}/components/sli_wifi/src/sli_wifi.c",
    "${wifi_sdk_root}/components/sli_wifi/src/sli_wifi_utility.c",
  ]

  public_configs = [ ":siwx-ncp-config" ]

  deps = [ "${chip_root}/src/platform:platform_base" ]
}
