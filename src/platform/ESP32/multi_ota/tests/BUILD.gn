import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")

import("${chip_root}/build/chip/chip_test_suite.gni")

chip_test_suite("tests") {
  output_name = "libMultiOTAImageHeaderTests"

  test_sources = [ "TestMultiOTAImageHeader.cpp" ]

  # The multi-image header parser is platform independent, so compile it directly
  # here (it is otherwise only part of the ESP32-only platform library).
  sources = [
    "${chip_root}/src/platform/ESP32/multi_ota/MultiOTAImageHeader.cpp",
    "${chip_root}/src/platform/ESP32/multi_ota/MultiOTAImageHeader.h",
  ]

  public_deps = [
    "${chip_root}/src/crypto",
    "${chip_root}/src/lib/core",
    "${chip_root}/src/lib/core:string-builder-adapters",
    "${chip_root}/src/lib/support",
  ]
}
