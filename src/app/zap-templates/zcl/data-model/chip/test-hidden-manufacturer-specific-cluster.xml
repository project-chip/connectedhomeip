<!--
  Test cluster for validating manufacturer-specific cluster handling in CI.

  Reproduces an SVE finding: a vendor's device exposed a manufacturer-
  specific cluster the Python test harness had no codegen for, which
  crashed TC_IDM_2_2 wildcard reads. Adding that scenario into
  all-clusters-app prevents the regression from returning.

  Cluster ID: 0xFFF1FC21 (4294048801)
  - Vendor ID: 0xFFF1 (test vendor)
  - Cluster suffix: 0xFC21 (within manufacturer-specific range 0xFC00-0xFFFE per spec)
-->
<configurator>
  <domain name="CHIP"/>

  <cluster apiMaturity="internal">
    <domain>CHIP</domain>
    <name>Test Hidden Manufacturer Specific</name>
    <code>0xFFF1FC21</code>
    <define>TEST_HIDDEN_MANUFACTURER_SPECIFIC</define>
    <description>Test cluster for validating manufacturer-specific cluster handling without controller-side implementation</description>

    <attribute side="server" code="0x0000" define="TEST_ATTRIBUTE" type="boolean" writable="false" default="true" optional="false">TestAttribute</attribute>
  </cluster>
</configurator>
