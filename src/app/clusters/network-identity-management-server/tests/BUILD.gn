import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")

import("${chip_root}/build/chip/chip_test_suite.gni")
import("${chip_root}/src/crypto/crypto.gni")

chip_test_suite("tests") {
  output_name = "libTestNetworkIdentityManagement"

  test_sources = [
    "TestDefaultNetworkIdentityStorage.cpp",
    "TestNetworkAdministratorSecret.cpp",
    "TestNetworkIdentityManagementCluster.cpp",
  ]

  if (chip_crypto_keystore == "raw") {
    test_sources += [ "TestRawKeyNetworkIdentityKeystore.cpp" ]
  }

  cflags = [
    "-Wconversion",
    "-Wsign-compare",
    "-Werror",
  ]

  public_deps = [
    "${chip_root}/src/app/clusters/network-identity-management-server",
    "${chip_root}/src/app/server-cluster/testing",
    "${chip_root}/src/credentials",
    "${chip_root}/src/lib/support",
    "${chip_root}/src/lib/support:testing",
  ]
}
