import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")
import("//build_overrides/pigweed.gni")

import("${chip_root}/build/chip/chip_test_suite.gni")

chip_test_suite("tests") {
  output_name = "TestCommissioningProxyCluster"

  test_sources = [ "TestCommissioningProxyCluster.cpp" ]

  # Compile only the cluster logic files.  CodegenIntegration.cpp is
  # intentionally excluded: it calls CodegenDataModelProvider::Instance()
  # which requires mock_model (and its mock_ember transitive dep).  In the
  # Zephyr monolithic test binary, mock_ember conflicts with real Ember,
  # causing duplicate-symbol linker errors.  The backwards-compat suite below
  # covers CodegenIntegration.  It is pulled into the build only as a
  # standalone host binary (chip_link_tests); the monolithic test aggregation
  # in src/BUILD.gn references only ":tests", so mock_model/mock_ember never
  # enters the Zephyr binary.
  sources = [
    "../CommissioningProxyCluster.cpp",
    "../CommissioningProxyCluster.h",
    "CommissioningProxyMockTransport.cpp",
    "CommissioningProxyMockTransport.h",
  ]

  cflags = [ "-Wconversion" ]

  # No transport defines are forced here.  CHIP_DEVICE_CONFIG_ENABLE_WIFIPAF and
  # CONFIG_NETWORK_LAYER_BLE are defined without #ifndef guards in
  # CHIPDeviceBuildConfig.h / BleBuildConfig.h (generated by buildconfig_header()),
  # so redefining them via GN `defines` would be a macro-redefinition error.
  # Tests instead read GetSupportedTransports() at runtime and skip transport-
  # specific cases when the corresponding bit is absent.

  public_deps = [
    "${chip_root}/src/app/clusters/commissioning-proxy-server",
    "${chip_root}/src/app/data-model-provider/tests:encode-decode",
    "${chip_root}/src/app/server-cluster/testing",
    "${chip_root}/src/lib/support",
    "${chip_root}/src/lib/support:timer-delegate-mock",
  ]
}

# Host-only suite that links the codegen data-model provider (mock_model /
# mock_ember) to exercise CodegenIntegration.cpp. It cannot join the monolithic
# single-binary build (ember symbol collisions), so src/BUILD.gn restricts it to
# linux/darwin. This is not a backwards-compatibility suite: CommissioningProxy is
# a new cluster; it only shares the host-only mock_ember build constraint.
chip_test_suite("tests-codegen-integration") {
  import(
      "${chip_root}/src/app/clusters/commissioning-proxy-server/app_config_dependent_sources.gni")

  output_name = "TestCommissioningProxyClusterCodegenIntegration"

  test_sources = [ "TestCommissioningProxyClusterCodegenIntegration.cpp" ]

  # Prefix app_config_dependent_sources with "../" and add to the sources list
  sources = []
  foreach(file, app_config_dependent_sources) {
    sources += [ "../" + file ]
  }
  sources += [
    "CommissioningProxyMockTransport.cpp",
    "CommissioningProxyMockTransport.h",
  ]

  cflags = [ "-Wconversion" ]

  public_deps = [
    "${chip_root}/src/app/clusters/commissioning-proxy-server",
    "${chip_root}/src/app/data-model-provider/tests:encode-decode",
    "${chip_root}/src/app/server-cluster/testing",
    "${chip_root}/src/data-model-providers/codegen/tests:mock_model",
    "${chip_root}/src/lib/support",
    "${chip_root}/src/lib/support:timer-delegate-mock",
  ]
}
