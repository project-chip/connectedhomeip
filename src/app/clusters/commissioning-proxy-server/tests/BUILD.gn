import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")
import("//build_overrides/pigweed.gni")

import("${chip_root}/build/chip/chip_test_suite.gni")

chip_test_suite("tests") {
  output_name = "TestCommissioningProxyCluster"

  test_sources = [ "TestCommissioningProxyCluster.cpp" ]

  # Compile only the cluster logic files.  CodegenIntegration.cpp is
  # intentionally excluded: it calls CodegenDataModelProvider::Instance()
  # which requires mock_model (and its mock_ember transitive dep).  In the
  # Zephyr monolithic test binary, mock_ember conflicts with real Ember,
  # causing duplicate-symbol linker errors.  The backwards-compat suite below
  # covers CodegenIntegration and is restricted to darwin/linux where
  # individual binaries are linked.
  sources = [
    "../CommissioningProxyCluster.cpp",
    "../CommissioningProxyCluster.h",
    "../CommissioningProxyDelegate.h",
    "CommissioningProxyMockDelegate.cpp",
    "CommissioningProxyMockDelegate.h",
  ]

  cflags = [ "-Wconversion" ]

  # NOTE: CHIP_DEVICE_CONFIG_ENABLE_WIFIPAF and CONFIG_NETWORK_LAYER_BLE are
  # intentionally NOT forced here.  Those macros are defined without #ifndef
  # guards in CHIPDeviceBuildConfig.h / BleBuildConfig.h (generated by the
  # buildconfig_header() template).  Redefining them via GN `defines` would
  # produce a macro-redefinition error when the two values differ.
  # Tests use GetSupportedTransports() at runtime and skip transport-specific
  # cases when the corresponding bit is absent.
  defines = [ "CHIP_DEVICE_CONFIG_ENABLE_COMMISSIONING_PROXY=1" ]

  public_deps = [
    "${chip_root}/src/app/clusters/commissioning-proxy-server",
    "${chip_root}/src/app/data-model-provider/tests:encode-decode",
    "${chip_root}/src/app/server-cluster/testing",
    "${chip_root}/src/lib/support",
    "${chip_root}/src/lib/support:timer-delegate-mock",
  ]
}

chip_test_suite("tests-backwards-compatibility") {
  import(
      "${chip_root}/src/app/clusters/commissioning-proxy-server/app_config_dependent_sources.gni")

  output_name = "TestCommissioningProxyClusterBackwardsCompatibility"

  test_sources = [ "TestCommissioningProxyClusterBackwardsCompatibility.cpp" ]

  # Prefix app_config_dependent_sources with "../" and add to the sources list
  sources = []
  foreach(file, app_config_dependent_sources) {
    sources += [ "../" + file ]
  }
  sources += [
    "CommissioningProxyMockDelegate.cpp",
    "CommissioningProxyMockDelegate.h",
  ]

  cflags = [ "-Wconversion" ]

  public_deps = [
    "${chip_root}/src/app/clusters/commissioning-proxy-server",
    "${chip_root}/src/app/data-model-provider/tests:encode-decode",
    "${chip_root}/src/app/server-cluster/testing",
    "${chip_root}/src/data-model-providers/codegen/tests:mock_model",
    "${chip_root}/src/lib/support",
    "${chip_root}/src/lib/support:timer-delegate-mock",
  ]
}
