import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")
import("//build_overrides/pigweed.gni")

import("${chip_root}/src/crypto/crypto.gni")

source_set("posix") {
  public_deps = [
    "$dir_pw_unit_test",
    "$dir_pw_unit_test:googletest_style_event_handler",
    "$dir_pw_unit_test:simple_printing_event_handler",
    "${chip_root}/src/lib/support",
    "${chip_root}/src/lib/support:arg_parser",
  ]

  # unit_test_main.cpp reads CHIP_CRYPTO_PSA (from CryptoBuildConfig.h) and, for
  # the PSA backend, calls psa_crypto_init() once so the whole suite is ready.
  deps = [ "${chip_root}/src/crypto:crypto_buildconfig" ]
  if (chip_crypto == "psa") {
    deps += [ "${chip_root}/third_party/mbedtls" ]
  }

  sources = [ "unit_test_main.cpp" ]
}
