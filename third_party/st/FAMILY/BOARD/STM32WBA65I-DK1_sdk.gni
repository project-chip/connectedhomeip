  "${stm32_util}/LCD",
  "${stm32_wb_bsp}/STM32WBA65I-DK1",
  "${stm32_wb_bsp}/Components/ssd1315",
  "${stm32_wb_bsp}/Components/Common",
]

DEFINES = []

LIBS = []

FLAGS = []
