import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")

declare_args() {
  ## PATHS FOR STM32WB BOARD ##
  stm32_board_src =
      "${chip_root}/examples/platform/stm32/common/STM32WBA65I-DK1"
  stm32_wb_bsp = "${chip_root}/third_party/st/STM32CubeWBA/Drivers/BSP"

  ## PATHS FOR ST UTILITIES ##
  stm32_util = "${chip_root}/third_party/st/STM32CubeWBA/Utilities"
}

SOURCES = [
  # BOARD APPLICATION SRC(in examples/platform/stm32/common/STM32WBA65I-DK1/)
  "${stm32_board_src}/Src/app_nvm.c",
  "${stm32_board_src}/Src/app_freertos.c",
  "${stm32_board_src}/Src/stm32wbaxx_hal_msp.c",
  "${stm32_board_src}/Src/stm32wbaxx_it.c",
  "${stm32_board_src}/Src/syscalls.c",
  "${stm32_board_src}/Src/sysmem.c",
  "${stm32_board_src}/Src/system_stm32wbaxx.c",
  "${stm32_board_src}/Src/stm32_factorydata.c",

  "${chip_root}/examples/platform/stm32/config_files/STM32WBA6/matter_config.h",
  "${chip_root}/examples/platform/stm32/config_files/STM32WBA6/FreeRTOSConfig.h",

  "${stm32_wb_bsp}/STM32WBA65I-DK1/stm32wba65i_discovery_bus.c",
  "${stm32_wb_bsp}/STM32WBA65I-DK1/stm32wba65i_discovery_lcd.c",
