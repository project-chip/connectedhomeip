  "${stm32_util}/misc/stm32_mem.c",
  "${stm32_util}/misc/stm32_systime.c",
  "${stm32_util}/misc/stm32_tiny_sscanf.c",
  "${stm32_util}/misc/stm32_tiny_vsnprintf.c",
  "${stm32_util}/tim_serv/stm32_timer.c",
  "${stm32_util}/LCD/stm32_lcd.c",
]

INCLUDE_DIRS = [
  "${stm32_util}",
  "${stm32_board_src}/Inc",
  "${stm32_board_src}/STM32_WPAN/App",
  "${stm32_util}/trace/adv_trace",
  "${stm32_util}/lpm/tiny_lpm",
