<cluster xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="types types.xsd cluster cluster.xsd" id="0x0431" name="Ambient Context Sensing Cluster" revision="1">
  <revisionHistory>
    <revision revision="1" summary="Initial revision"/>
  </revisionHistory>
  <clusterIds>
    <clusterId id="0x0431" name="Ambient Context Sensing">
      <provisionalConform/>
    </clusterId>
  </clusterIds>
  <classification hierarchy="base" role="application" picsCode="ACS" scope="Endpoint"/>
  <features>
    <feature bit="0" code="HA" name="HumanActivity" summary="Supports various human actions and activities classification">
      <otherwiseConform>
        <provisionalConform/>
        <optionalConform choice="a" more="true" min="1"/>
      </otherwiseConform>
    </feature>
    <feature bit="1" code="OC" name="ObjectCounting" summary="Supports object counting">
      <otherwiseConform>
        <provisionalConform/>
        <optionalConform choice="a" more="true" min="1"/>
      </otherwiseConform>
    </feature>
    <feature bit="2" code="OI" name="ObjectIdentification" summary="Supports object identification">
      <otherwiseConform>
        <provisionalConform/>
        <optionalConform choice="a" more="true" min="1"/>
      </otherwiseConform>
    </feature>
    <feature bit="3" code="AUD" name="SoundIdentification" summary="Supports sound identification">
      <otherwiseConform>
        <provisionalConform/>
        <optionalConform choice="a" more="true" min="1"/>
      </otherwiseConform>
    </feature>
    <feature bit="4" code="PRED" name="PredictedActivity" summary="Supports predicting various human actions and activities.">
      <otherwiseConform>
        <provisionalConform/>
        <optionalConform/>
      </otherwiseConform>
    </feature>
  </features>
  <dataTypes>
    <struct name="AmbientContextTypeStruct">
      <field id="0" name="AmbientContextSensed" type="list">
        <entry type="SemanticTagStruct"/>
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
        <constraint>
          <maxCount value="2"/>
        </constraint>
      </field>
    </struct>
    <struct name="HoldTimeLimitsStruct">
      <field id="0" name="HoldTimeMin" type="uint16">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
        <constraint>
          <min value="1"/>
        </constraint>
      </field>
      <field id="1" name="HoldTimeMax" type="uint16">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
        <constraint>
          <min>
            <maxOf>
              <field name="HoldTimeMin"/>
              <value>10</value>
            </maxOf>
          </min>
        </constraint>
      </field>
      <field id="2" name="HoldTimeDefault" type="uint16">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
        <constraint>
          <between>
            <from>
              <field name="HoldTimeMin"/>
            </from>
            <to>
              <field name="HoldTimeMax"/>
            </to>
          </between>
        </constraint>
      </field>
    </struct>
    <struct name="ObjectCountConfigStruct">
      <field id="0" name="CountingObject" type="SemanticTagStruct">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
      </field>
      <field id="1" name="ObjectCountThreshold" type="uint16">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
        <constraint>
          <min value="1"/>
        </constraint>
      </field>
    </struct>
    <struct name="PredictedActivityStruct">
      <field id="0" name="StartTimestamp" type="epoch-s">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
        <constraint>
          <max>
            <compute>
              <operation>subtract</operation>
              <left>
                <field name="EndTimestamp"/>
              </left>
              <right value="1"/>
            </compute>
          </max>
        </constraint>
      </field>
      <field id="1" name="EndTimestamp" type="epoch-s">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
        <constraint>
          <min>
            <compute>
              <operation>add</operation>
              <left>
                <field name="StartTimestamp"/>
              </left>
              <right value="1"/>
            </compute>
          </min>
        </constraint>
      </field>
      <field id="2" name="AmbientContextType" type="list">
        <entry type="SemanticTagStruct"/>
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform>
            <feature name="HA"/>
          </mandatoryConform>
          <mandatoryConform>
            <feature name="OI"/>
          </mandatoryConform>
          <mandatoryConform>
            <feature name="AUD"/>
          </mandatoryConform>
        </otherwiseConform>
        <constraint>
          <maxCount value="100"/>
        </constraint>
      </field>
      <field id="3" name="CrowdDetected" type="bool">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform>
            <feature name="OC"/>
          </mandatoryConform>
        </otherwiseConform>
      </field>
      <field id="4" name="CrowdCount" type="uint8">
        <otherwiseConform>
          <provisionalConform/>
          <optionalConform>
            <feature name="OC"/>
          </optionalConform>
        </otherwiseConform>
        <constraint>
          <between>
            <from value="1"/>
            <to value="254"/>
          </between>
        </constraint>
      </field>
      <field id="5" name="Confidence" type="percent">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
      </field>
    </struct>
  </dataTypes>
  <attributes>
    <attribute id="0x0000" name="HumanActivityDetected" type="bool">
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="HA"/>
        </mandatoryConform>
      </otherwiseConform>
    </attribute>
    <attribute id="0x0001" name="ObjectIdentified" type="bool">
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="OI"/>
        </mandatoryConform>
      </otherwiseConform>
    </attribute>
    <attribute id="0x0002" name="AudioContextDetected" type="bool">
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="AUD"/>
        </mandatoryConform>
      </otherwiseConform>
    </attribute>
    <attribute id="0x0003" name="AmbientContextType" type="list">
      <entry type="AmbientContextTypeStruct"/>
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="HA"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="OI"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="AUD"/>
        </mandatoryConform>
      </otherwiseConform>
      <constraint>
        <countBetween>
          <from value="1"/>
          <to>
            <attribute name="SimultaneousDetectionLimit"/>
          </to>
        </countBetween>
      </constraint>
    </attribute>
    <attribute id="0x0004" name="AmbientContextTypeSupported" type="list">
      <entry type="SemanticTagStruct"/>
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="HA"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="OI"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="AUD"/>
        </mandatoryConform>
      </otherwiseConform>
      <constraint>
        <maxCount value="50"/>
      </constraint>
    </attribute>
    <attribute id="0x0005" name="ObjectCountReached" type="bool">
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <andTerm>
            <feature name="OC"/>
            <feature name="OI"/>
          </andTerm>
        </mandatoryConform>
      </otherwiseConform>
    </attribute>
    <attribute id="0x0006" name="ObjectCountConfig" type="ObjectCountConfigStruct">
      <access read="true" write="true" readPrivilege="view" writePrivilege="manage"/>
      <quality persistence="nonVolatile"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <andTerm>
            <feature name="OC"/>
            <feature name="OI"/>
          </andTerm>
        </mandatoryConform>
      </otherwiseConform>
    </attribute>
    <attribute id="0x0007" name="ObjectCount" type="uint16" default="null">
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <optionalConform>
          <andTerm>
            <feature name="OC"/>
            <feature name="OI"/>
          </andTerm>
        </optionalConform>
      </otherwiseConform>
      <constraint>
        <min value="1"/>
      </constraint>
    </attribute>
    <attribute id="0x0008" name="SimultaneousDetectionLimit" type="uint8">
      <access read="true" write="true" readPrivilege="view" writePrivilege="operate"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform/>
      </otherwiseConform>
      <constraint>
        <max value="10"/>
      </constraint>
    </attribute>
    <attribute id="0x0009" name="HoldTime" type="uint16">
      <access read="true" write="true" readPrivilege="view" writePrivilege="manage"/>
      <quality persistence="nonVolatile"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform/>
      </otherwiseConform>
      <constraint>
        <between>
          <from>
            <attribute name="HoldTimeLimits">
              <field name="HoldTimeMin"/>
            </attribute>
          </from>
          <to>
            <attribute name="HoldTimeLimits">
              <field name="HoldTimeMax"/>
            </attribute>
          </to>
        </between>
      </constraint>
    </attribute>
    <attribute id="0x000A" name="HoldTimeLimits" type="HoldTimeLimitsStruct">
      <access read="true" readPrivilege="view"/>
      <quality persistence="fixed"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform/>
      </otherwiseConform>
    </attribute>
    <attribute id="0x000B" name="PredictedActivity" type="list">
      <entry type="PredictedActivityStruct"/>
      <access read="true" readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="PRED"/>
        </mandatoryConform>
      </otherwiseConform>
      <constraint>
        <maxCount value="20"/>
      </constraint>
    </attribute>
  </attributes>
  <events>
    <event id="0x00" name="AmbientContextDetectStarted" priority="info">
      <access readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="HA"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="OI"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="AUD"/>
        </mandatoryConform>
        <mandatoryConform>
          <andTerm>
            <feature name="OC"/>
            <feature name="OI"/>
          </andTerm>
        </mandatoryConform>
      </otherwiseConform>
      <field id="0" name="AmbientContextDetected" type="AmbientContextTypeStruct">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform>
            <feature name="HA"/>
          </mandatoryConform>
          <mandatoryConform>
            <feature name="OI"/>
          </mandatoryConform>
          <mandatoryConform>
            <feature name="OC"/>
          </mandatoryConform>
          <mandatoryConform>
            <feature name="AUD"/>
          </mandatoryConform>
        </otherwiseConform>
      </field>
      <field id="1" name="ObjectCountReached" type="bool">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform>
            <andTerm>
              <feature name="OC"/>
              <feature name="OI"/>
            </andTerm>
          </mandatoryConform>
        </otherwiseConform>
      </field>
      <field id="2" name="ObjectCount" type="uint16" default="null">
        <otherwiseConform>
          <provisionalConform/>
          <optionalConform>
            <andTerm>
              <feature name="OC"/>
              <feature name="OI"/>
            </andTerm>
          </optionalConform>
        </otherwiseConform>
        <constraint>
          <min value="1"/>
        </constraint>
      </field>
    </event>
    <event id="0x01" name="AmbientContextDetectEnded" priority="info">
      <access readPrivilege="view"/>
      <otherwiseConform>
        <provisionalConform/>
        <mandatoryConform>
          <feature name="HA"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="OI"/>
        </mandatoryConform>
        <mandatoryConform>
          <feature name="AUD"/>
        </mandatoryConform>
        <mandatoryConform>
          <andTerm>
            <feature name="OC"/>
            <feature name="OI"/>
          </andTerm>
        </mandatoryConform>
      </otherwiseConform>
      <field id="0" name="EventStartTime" type="posix-ms">
        <otherwiseConform>
          <provisionalConform/>
          <mandatoryConform/>
        </otherwiseConform>
      </field>
    </event>
  </events>
</cluster>
