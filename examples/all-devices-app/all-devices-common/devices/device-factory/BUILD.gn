import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")
import("${chip_root}/build/chip/buildconfig_header.gni")
import(
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/enabled_devices.gni")

# Generate app_config/enabled_devices.h.
# Will define a set of ALL_DEVICES_ENABLE_* constants
enabled_devices_buildconfig_header("enabled_devices_buildconfig") {
  header = "enabled_devices.h"
  header_dir = "app_config"
}

source_set("device-factory") {
  sources = [ "DeviceFactory.h" ]

  public_deps = [
    ":enabled_devices_buildconfig",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/boolean-state-sensor",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/chime",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/dimmable-light/impl:logging",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/occupancy-sensor/impl:toggling",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/on-off-light",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/soil-sensor/impl:increasing",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/speaker/impl:logging",
    "${chip_root}/examples/all-devices-app/all-devices-common/devices/temperature-sensor/impl:increasing",
    "${chip_root}/src/lib/support",
  ]
}
